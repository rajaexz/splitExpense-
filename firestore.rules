rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection - users can read/write their own data
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Usernames lookup - for registration uniqueness check (unauthenticated get allowed)
    match /usernames/{username} {
      allow get: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Groups collection
    match /groups/{groupId} {
      // Anyone authenticated can read individual groups and list all groups
      allow read: if isAuthenticated();
      allow list: if isAuthenticated();
      allow get: if isAuthenticated();
      
      // Anyone authenticated can create a group
      allow create: if isAuthenticated() && 
        request.resource.data.creatorId == request.auth.uid;
      
      // Only creator can update/delete
      allow update, delete: if isAuthenticated() && 
        resource.data.creatorId == request.auth.uid;
      
      // Group members subcollection (if used)
      match /members/{memberId} {
        // Group members can read, anyone authenticated can read for discovery
        allow read: if isAuthenticated();
        // Users can add themselves, creator can add anyone
        allow create: if isAuthenticated() && (
          memberId == request.auth.uid ||
          get(/databases/$(database)/documents/groups/$(groupId)).data.creatorId == request.auth.uid
        );
        // Users can update their own member data, creator can update anyone
        allow update: if isAuthenticated() && (
          memberId == request.auth.uid ||
          get(/databases/$(database)/documents/groups/$(groupId)).data.creatorId == request.auth.uid
        );
        // Users can remove themselves, creator can remove anyone
        allow delete: if isAuthenticated() && (
          memberId == request.auth.uid ||
          get(/databases/$(database)/documents/groups/$(groupId)).data.creatorId == request.auth.uid
        );
      }
    }
    
    // Messages collection - organized by groupId with messages subcollection
    match /messages/{groupId}/messages/{messageId} {
      // Helper function to check if user is a group member
      function isGroupMember() {
        return isAuthenticated() && 
          get(/databases/$(database)/documents/groups/$(groupId)).data.members[request.auth.uid] != null;
      }
      
      // Only group members can read messages
      allow read: if isGroupMember();
      
      // Only group members can write messages
      allow create: if isGroupMember() && 
        request.resource.data.senderId == request.auth.uid;
      
      // Sender can update/delete their own; group members can update (e.g. mark as read)
      allow update: if isGroupMember();
      allow delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }
    
    // Locations collection - for location sharing
    match /locations/{groupId}/{userId} {
      // Helper function to check if user is a group member
      function isGroupMember() {
        return isAuthenticated() && 
          get(/databases/$(database)/documents/groups/$(groupId)).data.members[request.auth.uid] != null;
      }
      
      // Group members can read locations
      allow read: if isGroupMember();
      
      // Users can only write their own location
      allow write: if isAuthenticated() && 
        userId == request.auth.uid &&
        isGroupMember();
    }
    
      // Group question games - subcollection under groups
      match /groups/{groupId}/games/{gameId} {
        function isGroupMemberGame() {
          return isAuthenticated() &&
            get(/databases/$(database)/documents/groups/$(groupId)).data.members[request.auth.uid] != null;
        }
        allow read: if isGroupMemberGame();
        allow create: if isAuthenticated() &&
          request.resource.data.hostId == request.auth.uid &&
          isGroupMemberGame();
        allow update, delete: if isGroupMemberGame();
      }

      // Expenses - subcollection under groups (trip expense tracking)
      match /groups/{groupId}/expenses/{expenseId} {
      // Helper function to check if user is a group member
      function isGroupMember() {
        return isAuthenticated() && 
          get(/databases/$(database)/documents/groups/$(groupId)).data.members[request.auth.uid] != null;
      }
      
      // Group members can read expenses
      allow read: if isGroupMember();
      
      // Group members can create expenses; createdBy must be current user
      allow create: if isGroupMember() &&
        request.resource.data.createdBy == request.auth.uid;
      
      // Sirf jisne add kiya (createdBy) woh edit/delete kar sakta hai
      allow update, delete: if isGroupMember() &&
        resource.data.createdBy == request.auth.uid;
    }
    
    // Shared galleries - owner creates, shared friends can read
    match /gallery_shares/{shareId} {
      allow read: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.sharedWith
      );
      allow create: if isAuthenticated() && 
        request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
        resource.data.ownerId == request.auth.uid;
    }
    
    // Group history - deleted groups for creator to view
    match /group_history/{historyId} {
      allow read: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Notifications collection
    match /notifications/{userId}/notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isOwner(userId);
      // Authenticated users can create notifications (e.g. when sending group messages)
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(userId);
    }
  }
}

